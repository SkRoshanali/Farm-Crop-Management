# Root .gitignore for farm-crop-system

# Backend
backend/target/
backend/*.class
backend/*.jar
backend/*.war
backend/.idea/
backend/*.iml
backend/.vscode/
backend/*.log
backend/logs/

# Frontend
frontend/node_modules/
frontend/build/
frontend/dist/

# Generic
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Environment variables - NEVER commit these!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
backend/.env.local
backend/.env.*.local
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

# Application properties with sensitive data
backend/application-dev.properties.local
backend/application-prod.properties.local
