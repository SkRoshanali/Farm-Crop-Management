# ========================================
# Farm Crop Management System - Environment Variables
# ========================================
# IMPORTANT: Copy this file to .env and fill in your values
# Never commit .env to version control!

# Database Configuration
DB_NAME=farm_crop_db
DB_USERNAME=farmuser
DB_PASSWORD=your_secure_password_here

# JWT Configuration
JWT_SECRET=your_256_bit_secret_key_here_use_openssl_rand_base64_32
JWT_EXPIRATION=86400000

# Spring Profile (dev, prod)
SPRING_PROFILES_ACTIVE=prod

# Frontend API URL
REACT_APP_API_BASE_URL=http://localhost:8080/api

# ========================================
# SECURITY NOTES:
# ========================================
# 1. Generate secure JWT secret:
#    openssl rand -base64 32
#
# 2. Use strong database password (min 16 chars)
#
# 3. In production, use environment-specific secrets
#
# 4. Never expose these values in logs or error messages
#
# 5. Rotate secrets regularly (every 90 days recommended)
